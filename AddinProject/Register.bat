@echo off
:: Mind Map Studio - Register Only (no build needed)
:: Double-click this to (re)register the add-in at any time.

powershell.exe -NoProfile -ExecutionPolicy Bypass -Command ^
  "$guid='C1A2B3D4-E5F6-7A8B-9C0D-E1F2A3B4C5D6'; $progId='MindMapStudio.Connect'; $dllPath=\"$env:LOCALAPPDATA\MindMapStudio\MindMapStudio.dll\"; if(-not(Test-Path $dllPath)){Write-Host 'ERROR: DLL not found at '$dllPath; Read-Host; exit 1}; $dllUri='file:///'+$dllPath.Replace('\','/'); $asm='MindMapStudio, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null'; $p=\"HKCU:\Software\Classes\CLSID\{$guid}\InprocServer32\"; New-Item -Path $p -Force|Out-Null; Set-ItemProperty $p '(Default)' 'mscoree.dll'; Set-ItemProperty $p 'Class' 'MindMapStudio.Connect'; Set-ItemProperty $p 'Assembly' $asm; Set-ItemProperty $p 'RuntimeVersion' 'v4.0.30319'; Set-ItemProperty $p 'ThreadingModel' 'Both'; Set-ItemProperty $p 'CodeBase' $dllUri; New-Item 'HKCU:\Software\Classes\CLSID\{$guid}\ProgId' -Force|Out-Null; Set-ItemProperty \"HKCU:\Software\Classes\CLSID\{$guid}\ProgId\" '(Default)' $progId; New-Item \"HKCU:\Software\Classes\$progId\CLSID\" -Force|Out-Null; Set-ItemProperty \"HKCU:\Software\Classes\$progId\" '(Default)' 'Mind Map Studio'; Set-ItemProperty \"HKCU:\Software\Classes\$progId\CLSID\" '(Default)' \"{$guid}\"; $a=\"HKCU:\Software\Microsoft\Office\OneNote\AddIns\$progId\"; New-Item $a -Force|Out-Null; Set-ItemProperty $a 'FriendlyName' 'Mind Map Studio'; Set-ItemProperty $a 'Description' 'Create and insert mind maps into OneNote'; Set-ItemProperty $a 'LoadBehavior' -Type DWord -Value 3; Write-Host 'Registered! Restart OneNote now.'; Read-Host 'Press Enter to close'"
